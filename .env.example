# ═══ DENT-ALP OS — Environment Variables ═══
# Coolify'da bu değerleri Environment Variables bölümüne girin

# PostgreSQL — Coolify'ın sağladığı DB URL veya Neon
DATABASE_URL="postgresql://user:password@host:5432/dental_db?sslmode=require"

# NextAuth — openssl rand -base64 32 ile üretin
NEXTAUTH_SECRET="your-32-char-secret-here"
NEXTAUTH_URL="https://dental.royalfnb.com"

# İlk deploy'da seed çalıştırmak için true yapın, sonra kaldırın
SEED_DB="false"

# Port (Coolify otomatik yönetir)
PORT=3000
